# HTTP-Zugriff auf diesen Ordner vollständig sperren.
# PHP-Includes funktionieren weiterhin (Dateisystem, kein HTTP).

# Apache 2.4+
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2 (Fallback)
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
